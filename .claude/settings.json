{
  "permissions": {
    "allow": [
      "Bash(npx playwright test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run:*)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run download:*)",
      "Bash(gh pr diff:*)",
      "Bash(playwright-cli:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/secrets/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint-changed.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck-on-stop.sh",
            "timeout": 120,
            "statusMessage": "Type-checking changed TypeScript"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-test-only.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "flaky-investigator",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Verify the subagent returned a concrete root cause and the specific lines to change. If it only described symptoms without a root cause, tell it to continue investigating.",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
