{
  "name": "poc-pw-cli-ai",
  "version": "1.0.0",
  "description": "AI-native Playwright + TypeScript test automation framework, built as a migration-ready skeleton",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.10.0",
    "eslint": "^10.5.0",
    "eslint-plugin-playwright": "^2.10.0",
    "husky": "^9.1.0",
    "prettier": "^3.8.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
